generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  cognitoSub       String?  @unique @map("cognito_sub")
  name             String?
  signupRole       String?  @map("signup_role") // "coach" | "athlete" set once on welcome
  stripeCustomerId String?  @unique @map("stripe_customer_id") // for saved payment methods
  createdAt        DateTime @default(now()) @map("created_at")

  coachProfile      CoachProfile?
  athleteProfiles   AthleteProfile[]
}

model CoachProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName           String   @map("display_name")
  sports                String[] @default([])
  serviceCities         String[] @default([]) @map("service_cities")
  bio                   String   @default("")
  hourlyRate            Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  verified              Boolean  @default(false)
  backgroundCheckComplete Boolean @default(false) @map("background_check_complete")
  credentials           Json?    @default("{}")
  avatarUrl                 String?  @map("avatar_url")
  phone                     String?  @db.Text
  stripeConnectAccountId    String?  @unique @map("stripe_connect_account_id")
  stripeOnboardingComplete  Boolean  @default(false) @map("stripe_onboarding_complete")
  assistantDisplayName     String?  @map("assistant_display_name")
  assistantPhoneNumber     String?  @map("assistant_phone_number")
  assistantCapabilities    Json?    @map("assistant_capabilities") // e.g. { "scheduling": true, "bookings": true }
  planId                   String?  @map("plan_id") // "starter" | "pro" | "elite"
  billingMode              String   @default("after_session") @map("billing_mode") // "upfront" | "after_session"

  photos             CoachPhoto[]
  locations          CoachLocation[]
  serviceAreas       ServiceArea[]     @relation("CoachServiceAreas")
  availabilityRules  AvailabilityRule[]
  availabilitySlots AvailabilitySlot[]
  bookings          Booking[]         @relation("CoachBookings")
  reviews            Review[]
  invite             CoachInvite?
  coachAthletes     CoachAthlete[]    @relation("CoachAthletes")
  phoneOptIns       CoachAthletePhoneOptIn[]

  @@map("coach_profiles")
}

model CoachLocation {
  id        String       @id @default(uuid())
  coachId  String       @map("coach_id")
  coach    CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name     String       @map("name")
  address  String       @db.Text
  notes    String?      @db.Text
  latitude Decimal?     @db.Decimal(10, 7)
  longitude Decimal?   @db.Decimal(10, 7)

  availabilitySlots AvailabilitySlot[]
  availabilityRules AvailabilityRule[]

  @@map("coach_locations")
}

model AthleteProfile {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String   @map("display_name")
  serviceCity String?  @map("service_city")
  avatarUrl   String?  @map("avatar_url")
  birthYear   Int?     @map("birth_year")
  sports      String[] @default([])
  level       String?
  phone       String?  @map("phone")
  createdAt   DateTime @default(now()) @map("created_at")

  serviceAreas      ServiceArea[]  @relation("AthleteServiceAreas")
  coachAssociations CoachAthlete[] @relation("AthleteCoaches")
  bookings          Booking[]      @relation("AthleteBookings")
  reviews           Review[]

  @@map("athlete_profiles")
}

model CoachPhoto {
  id             String       @id @default(uuid())
  coachProfileId String       @map("coach_profile_id")
  coach          CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  url            String
  sortOrder      Int          @default(0) @map("sort_order")

  @@map("coach_photos")
}

model AvailabilityRule {
  id               String   @id @default(uuid())
  coachId          String   @map("coach_id")
  coach            CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  locationId       String?  @map("location_id")
  location         CoachLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  firstStartTime   DateTime @map("first_start_time")
  durationMinutes Int      @map("duration_minutes")
  recurrence      String   @default("weekly")
  endDate         DateTime @map("end_date")

  slots AvailabilitySlot[]

  @@map("availability_rules")
}

model AvailabilitySlot {
  id         String   @id @default(uuid())
  coachId    String   @map("coach_id")
  coach      CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  locationId String?  @map("location_id")
  location   CoachLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  ruleId     String?  @map("rule_id")
  rule       AvailabilityRule? @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  startTime  DateTime @map("start_time")
  endTime    DateTime @map("end_time")
  recurrence String   @default("none")
  status     String   @default("available")

  bookings Booking[]

  @@map("availability_slots")
}

model Booking {
  id                    String   @id @default(uuid())
  athleteProfileId      String   @map("athlete_profile_id")
  athleteProfile        AthleteProfile @relation("AthleteBookings", fields: [athleteProfileId], references: [id], onDelete: Cascade)
  coachId               String   @map("coach_id")
  coach                 CoachProfile @relation("CoachBookings", fields: [coachId], references: [id], onDelete: Cascade)
  slotId                String   @map("slot_id")
  slot                  AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  message               String?  @db.Text
  status                String   @default("pending")
  amountCents           Int?     @map("amount_cents")
  currency              String   @default("usd")
  stripePaymentIntentId String?  @map("stripe_payment_intent_id")
  paymentStatus         String?  @map("payment_status") // authorized, succeeded, refunded, failed, canceled
  createdAt             DateTime @default(now()) @map("created_at")
  completedAt           DateTime? @map("completed_at")
  coachRecap            String?  @map("coach_recap") @db.Text

  review Review?

  @@map("bookings")
}

model Review {
  id               String   @id @default(uuid())
  bookingId        String   @unique @map("booking_id")
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  coachId          String   @map("coach_id")
  coach            CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  athleteProfileId String   @map("athlete_profile_id")
  athleteProfile   AthleteProfile @relation(fields: [athleteProfileId], references: [id], onDelete: Cascade)
  rating           Int
  comment          String   @default("")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

model CoachInvite {
  id             String       @id @default(uuid())
  coachProfileId String       @unique @map("coach_profile_id")
  coach          CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  slug           String       @unique
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("coach_invites")
}

model CoachAthlete {
  id              String        @id @default(uuid())
  coachProfileId  String        @map("coach_profile_id")
  coach           CoachProfile  @relation("CoachAthletes", fields: [coachProfileId], references: [id], onDelete: Cascade)
  athleteProfileId String       @map("athlete_profile_id")
  athlete         AthleteProfile @relation("AthleteCoaches", fields: [athleteProfileId], references: [id], onDelete: Cascade)
  status          String        @default("active") // active | pending | blocked
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([coachProfileId, athleteProfileId])
  @@map("coach_athletes")
}

model CoachAthletePhoneOptIn {
  id             String       @id @default(uuid())
  coachProfileId String       @map("coach_profile_id")
  coach          CoachProfile @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  phoneE164      String       @map("phone_e164")
  optedInAt      DateTime     @default(now()) @map("opted_in_at")
  source         String       @default("sms_inbound") @map("source")

  @@unique([coachProfileId, phoneE164])
  @@map("coach_athlete_phone_opt_ins")
}

model ServiceArea {
  id               String          @id @default(uuid())
  label            String
  latitude         Decimal         @db.Decimal(10, 7)
  longitude        Decimal         @db.Decimal(10, 7)
  radiusMiles      Int             @default(15) @map("radius_miles")
  coachProfileId   String?         @map("coach_profile_id")
  coachProfile     CoachProfile?   @relation("CoachServiceAreas", fields: [coachProfileId], references: [id], onDelete: Cascade)
  athleteProfileId String?         @map("athlete_profile_id")
  athleteProfile   AthleteProfile? @relation("AthleteServiceAreas", fields: [athleteProfileId], references: [id], onDelete: Cascade)

  @@map("service_areas")
}
